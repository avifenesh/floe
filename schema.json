{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artifact",
  "description": "The top-level JSON artifact emitted by `adr diff`. Every downstream consumer (server, frontend, cost model, evidence collectors) reads this and only this.",
  "type": "object",
  "required": [
    "base",
    "head",
    "hunks",
    "pr",
    "schema_version"
  ],
  "properties": {
    "base": {
      "$ref": "#/definitions/Graph"
    },
    "base_cfg": {
      "description": "Per-function CFGs for the base snapshot, keyed by Function `NodeId` in `base`.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/CfgEntry"
      }
    },
    "flows": {
      "description": "Flows — groups of hunks that belong to one architectural story. The primary unit of review in v0.2. Deterministic structural clustering always produces this list; the `adr` PI extension may replace it with LLM-validated flows.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Flow"
      }
    },
    "head": {
      "$ref": "#/definitions/Graph"
    },
    "head_cfg": {
      "description": "Per-function CFGs for the head snapshot, keyed by Function `NodeId` in `head`.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/CfgEntry"
      }
    },
    "hunks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Hunk"
      }
    },
    "pr": {
      "$ref": "#/definitions/PrRef"
    },
    "schema_version": {
      "type": "string"
    }
  },
  "definitions": {
    "Cfg": {
      "type": "object",
      "required": [
        "edges",
        "nodes"
      ],
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CfgEdge"
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CfgNode"
          }
        }
      }
    },
    "CfgEdge": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "$ref": "#/definitions/CfgNodeId"
        },
        "to": {
          "$ref": "#/definitions/CfgNodeId"
        }
      }
    },
    "CfgEntry": {
      "description": "Per-function CFG binding. Keyed by the Function's `NodeId` in the enclosing [`crate::graph::Graph`]. Stored as a flat list (not a map) because JSON doesn't allow non-string map keys, and a wire-format map would waste tokens when the NodeId is already a u32.",
      "type": "object",
      "required": [
        "cfg",
        "function"
      ],
      "properties": {
        "cfg": {
          "$ref": "#/definitions/Cfg"
        },
        "function": {
          "$ref": "#/definitions/NodeId"
        }
      }
    },
    "CfgNode": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "span"
      ],
      "properties": {
        "id": {
          "$ref": "#/definitions/CfgNodeId"
        },
        "kind": {
          "$ref": "#/definitions/CfgNodeKind"
        },
        "span": {
          "$ref": "#/definitions/Span"
        }
      }
    },
    "CfgNodeId": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "CfgNodeKind": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "entry"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "exit"
              ]
            }
          }
        },
        {
          "description": "A straight-line sequence of statements; collapsed into one node for navigation purposes (we don't care about per-statement granularity at the CFG level — the source view keeps that).",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "seq"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "branch"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "loop"
              ]
            }
          }
        },
        {
          "description": "An `await` expression — a yield point that the flow view draws as a packet hop. `Throw` + `Try` capture exception edges.",
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "async-boundary"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "throw"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "try"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "return"
              ]
            }
          }
        }
      ]
    },
    "Edge": {
      "type": "object",
      "required": [
        "from",
        "id",
        "kind",
        "provenance",
        "to"
      ],
      "properties": {
        "from": {
          "$ref": "#/definitions/NodeId"
        },
        "id": {
          "$ref": "#/definitions/EdgeId"
        },
        "kind": {
          "$ref": "#/definitions/EdgeKind"
        },
        "provenance": {
          "$ref": "#/definitions/Provenance"
        },
        "to": {
          "$ref": "#/definitions/NodeId"
        }
      }
    },
    "EdgeId": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "EdgeKind": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "calls",
            "defines",
            "exports"
          ]
        },
        {
          "description": "A transition between two [`NodeKind::State`] variants.",
          "type": "object",
          "required": [
            "transitions"
          ],
          "properties": {
            "transitions": {
              "type": "object",
              "required": [
                "from",
                "to"
              ],
              "properties": {
                "from": {
                  "type": "string"
                },
                "to": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "Flow": {
      "description": "A flow — the primary unit of review in v0.2. Lives at `artifact.flows[]` (schema update lands with this crate).\n\nThe structural floor produces flows with `FlowSource::Structural`. The `adr` PI extension replaces the list with LLM-validated flows tagged `FlowSource::Llm`. If the LLM run is rejected, we ship the structural list unchanged and the UI surfaces a \"structural only\" banner.",
      "type": "object",
      "required": [
        "entities",
        "extra_entities",
        "hunk_ids",
        "id",
        "name",
        "order",
        "rationale",
        "source"
      ],
      "properties": {
        "entities": {
          "description": "Qualified entity names participating in this flow. Kept as strings so they match across base/head snapshots.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extra_entities": {
          "description": "Entities the LLM added beyond the hunk-derived set — unchanged callers/callees the reviewer should see in context. Empty for structural flows.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hunk_ids": {
          "description": "Every hunk that belongs to this flow. A hunk may appear in multiple flows (explicitly allowed). Every hunk in the artifact must appear in at least one flow (host-enforced when the LLM produces flows; guaranteed by construction when structural).",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "description": "Stable id — `flow-<blake3>` computed from the bucket name and hunk-id list. Two runs of the structural clustering on the same artifact produce identical ids.",
          "type": "string"
        },
        "name": {
          "description": "Reviewer-facing name. Structural flows use `<structural: <bucket>>`; LLM flows use an intent-shaped name.",
          "type": "string"
        },
        "order": {
          "description": "Render order — stable in structural output; LLM runs preserve whatever order the host finalises.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "rationale": {
          "description": "One-or-two-sentence explanation of why these hunks are together.",
          "type": "string"
        },
        "source": {
          "description": "Provenance of this flow — structural or LLM-synthesised.",
          "allOf": [
            {
              "$ref": "#/definitions/FlowSource"
            }
          ]
        }
      }
    },
    "FlowSource": {
      "oneOf": [
        {
          "description": "Structural clustering ran. No LLM involved or LLM output rejected.",
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "structural"
              ]
            }
          }
        },
        {
          "description": "LLM synthesis ran, validated, and was accepted by the host.",
          "type": "object",
          "required": [
            "kind",
            "model",
            "version"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "llm"
              ]
            },
            "model": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        }
      ]
    },
    "Graph": {
      "description": "Flat adjacency-list graph. `petgraph` is used internally for queries; the wire format stays flat so downstream languages can read the artifact without a graph library.",
      "type": "object",
      "required": [
        "edges",
        "nodes"
      ],
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Edge"
          }
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Node"
          }
        }
      }
    },
    "Hunk": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "provenance"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/HunkKind"
        },
        "provenance": {
          "$ref": "#/definitions/Provenance"
        }
      }
    },
    "HunkKind": {
      "description": "The three semantic hunk types scope 1 delivers. The RFC lists more (lock, data, docs, deletion); they land in later scopes without a schema bump — new variants are additive.",
      "oneOf": [
        {
          "description": "A call-graph edge appeared, disappeared, or moved.",
          "type": "object",
          "required": [
            "added_edges",
            "kind",
            "removed_edges"
          ],
          "properties": {
            "added_edges": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/EdgeId"
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "call"
              ]
            },
            "removed_edges": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/EdgeId"
              }
            }
          }
        },
        {
          "description": "A string-union state gained or lost variants, or transitions changed.",
          "type": "object",
          "required": [
            "added_variants",
            "kind",
            "node",
            "removed_variants"
          ],
          "properties": {
            "added_variants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "kind": {
              "type": "string",
              "enum": [
                "state"
              ]
            },
            "node": {
              "$ref": "#/definitions/NodeId"
            },
            "removed_variants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        {
          "description": "An exported API surface changed shape or a route handler moved.",
          "type": "object",
          "required": [
            "kind",
            "node"
          ],
          "properties": {
            "after_signature": {
              "type": [
                "string",
                "null"
              ]
            },
            "before_signature": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "type": "string",
              "enum": [
                "api"
              ]
            },
            "node": {
              "$ref": "#/definitions/NodeId"
            }
          }
        }
      ]
    },
    "Node": {
      "type": "object",
      "required": [
        "file",
        "id",
        "kind",
        "provenance",
        "span"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "id": {
          "$ref": "#/definitions/NodeId"
        },
        "kind": {
          "$ref": "#/definitions/NodeKind"
        },
        "provenance": {
          "$ref": "#/definitions/Provenance"
        },
        "span": {
          "$ref": "#/definitions/Span"
        }
      }
    },
    "NodeId": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "NodeKind": {
      "oneOf": [
        {
          "description": "A TypeScript function, method, or arrow-function definition.",
          "type": "object",
          "required": [
            "name",
            "signature",
            "type"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "signature": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "function"
              ]
            }
          }
        },
        {
          "description": "A type alias, interface, or class declared in the surface.",
          "type": "object",
          "required": [
            "name",
            "type"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "type"
              ]
            }
          }
        },
        {
          "description": "A string-union state (e.g. `type State = \"a\" | \"b\"`).",
          "type": "object",
          "required": [
            "name",
            "type",
            "variants"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "state"
              ]
            },
            "variants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        {
          "description": "An HTTP / RPC endpoint exposed by the repo (Next.js handler, etc.).",
          "type": "object",
          "required": [
            "method",
            "path",
            "type"
          ],
          "properties": {
            "method": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "api-endpoint"
              ]
            }
          }
        },
        {
          "description": "A source file referenced by other nodes.",
          "type": "object",
          "required": [
            "path",
            "type"
          ],
          "properties": {
            "path": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "file"
              ]
            }
          }
        }
      ]
    },
    "PrRef": {
      "type": "object",
      "required": [
        "base_sha",
        "head_sha",
        "repo"
      ],
      "properties": {
        "base_sha": {
          "type": "string"
        },
        "head_sha": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        }
      }
    },
    "Provenance": {
      "description": "Every node, edge, and hunk carries provenance so the UI can answer \"where did this fact come from?\" without guessing.\n\n`source` names the pass that produced the fact (e.g. `tree-sitter-typescript`, `scip-typescript`, `adr-hunks/call`). `version` is the tool version at the time of the run. `pass_id` is stable across a single analysis; `hash` is a blake3 of the raw input bytes the pass consumed — used to detect stale cached facts.",
      "type": "object",
      "required": [
        "hash",
        "pass_id",
        "source",
        "version"
      ],
      "properties": {
        "hash": {
          "type": "string"
        },
        "pass_id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      }
    },
    "Span": {
      "description": "Byte-range span in the indicated file. Line/column are derived on demand by the renderer; the artifact stays source-of-truth in bytes.",
      "type": "object",
      "required": [
        "end",
        "start"
      ],
      "properties": {
        "end": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "start": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    }
  }
}
