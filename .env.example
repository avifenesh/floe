# ─────────────────────────────────────────────────────────────────
# floe-server — environment reference
#
# Copy to .env and fill in what your deployment uses. Every knob is
# optional unless marked REQUIRED. Defaults live in the code; these
# values just override them.
# ─────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────
# Port the HTTP server binds to.
# FLOE_PORT=8787

# Writable directory for the artifact cache, baselines, and git
# checkouts. Parent must exist; server creates subdirs.
# FLOE_CACHE_DIR=.floe-cache

# Session cookie secret. Generate with `openssl rand -hex 32`.
# Required in production; dev-login only works without it locally.
# FLOE_SESSION_SECRET=

# When set to `1`, enables POST /auth/dev/login for a handle-based
# fake session. Never set on a deployed instance.
# FLOE_ALLOW_DEV_LOGIN=0

# Where sample PR fixtures live on disk (defaults to `fixtures/`).
# FLOE_SAMPLES_ROOT=fixtures

# ─── Database ────────────────────────────────────────────────────
# Full Postgres connection string.
# FLOE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/adr
# When FLOE_DATABASE_URL is absent and FLOE_DB=sqlite, falls back to
# a file-SQLite store (single-user dev only).
# FLOE_DB=postgres

# ─── LLM regime ──────────────────────────────────────────────────
# GLM (Zhipu) API key for cloud passes — synthesis / proof / intent
# summary run here when `FLOE_LLM` defaults to `glm`.
# FLOE_GLM_API_KEY=

# Which LLM the synth/proof/summary passes use. Values:
#   glm     (default) — glm-4.7 via FLOE_GLM_API_KEY
#   ollama           — local model via FLOE_OLLAMA_URL
#   skip             — no synth/proof pass
# FLOE_LLM=glm

# Per-pass overrides. Same values as FLOE_LLM; absence falls back to
# FLOE_LLM. Useful when you want cloud synthesis + local intent, etc.
# FLOE_PROBE_LLM=
# FLOE_PROOF_LLM=
# FLOE_INTENT_LLM=ollama
# FLOE_SUMMARY_LLM=

# Enable the intent-extraction pass that runs when a PR has no
# author-supplied intent (pulls from commit messages, README,
# changed filenames). `0` disables; `1` enables.
# FLOE_INTENT_EXTRACT=1

# ─── LSP enrichment (TS v2 Phase A) ──────────────────────────────
# Path to the typescript-language-server binary. When unset, the
# parser falls back to the tree-sitter call graph. Recommended.
# FLOE_TS_LSP=typescript-language-server

# Enable LSP-backed call-graph enrichment. `1` on, `0` off.
# FLOE_LSP_ENRICH=1

# ─── Compile pass (TS v2 Phase B1) ───────────────────────────────
# Run `tsc --noEmit` on base and head for a type-check delta.
# FLOE_COMPILE_PASS=1
# FLOE_COMPILE_TIMEOUT_SECS=180

# ─── External runs (TS v2 Phase B2) ──────────────────────────────
# Reviewer-configured test / bench commands — split on whitespace,
# no shell interpretation. Leave empty to skip.
# FLOE_TEST_CMD=vitest run
# FLOE_BENCH_CMD=
# FLOE_EXTERNAL_TIMEOUT_SECS=180
# FLOE_EXTERNAL_MAX_BYTES=65536

# Path (relative to base/head root) to an lcov.info / json-summary
# coverage file. Defaults scan `coverage/lcov.info` →
# `coverage/coverage-summary.json`. Override if yours lives elsewhere.
# FLOE_COVERAGE_FILE=coverage/lcov.info

# ─── GLM concurrency / rate-limit ────────────────────────────────
# Max concurrent in-flight GLM requests. Works with the shared
# circuit breaker to bound worst-case retries.
# FLOE_GLM_CONCURRENCY=3
